[project]
entrypoint = "src/main.py"
requires = ["python-3.12"]

[dev]
build = ["bash", "scripts/setup.sh"]
run = ["bash", "/workspace/projects/scripts/http_run.sh", "-p 5000"]
pack = ["bash", "/workspace/projects/scripts/pack.sh"]
deps = ["git"] # -> apt install git

[deploy]
# 默认部署：HTTP服务 + 定时调度器
build = ["bash", "scripts/setup.sh"]
run = ["bash", "scripts/combined_run.sh", "-p 5000"]
deps = ["git"]

[deploy.scheduler]
# 仅定时调度器（用于纯定时任务场景）
build = ["bash", "scripts/setup.sh"]
run = ["bash", "scripts/scheduler_run.sh"]
deps = ["git"]

[deploy.http]
# 仅HTTP服务（用于手动触发场景）
build = ["bash", "scripts/setup.sh"]
run = ["bash", "scripts/http_run.sh", "-p 5000"]
deps = ["git"]
